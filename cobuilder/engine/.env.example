# CoBuilder Engine — LLM Provider Configuration
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# The pipeline runner loads these at startup via load_engine_env().
# Supports $VAR expansion (e.g., ANTHROPIC_API_KEY=$DASHSCOPE_API_KEY).

# --- Anthropic (direct) ---
export ANTHROPIC_BASE_URL="https://api.anthropic.com"
export ANTHROPIC_API_KEY=sk-ant-your-key-here
export ANTHROPIC_MODEL="claude-sonnet-4-5-20250514"

# --- DashScope (Alibaba Cloud) — near-zero cost alternative ---
# Sign up at: https://dashscope.console.aliyun.com/
# export ANTHROPIC_BASE_URL="https://coding-intl.dashscope.aliyuncs.com/apps/anthropic"
# export DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
# export ANTHROPIC_API_KEY=$DASHSCOPE_API_KEY
# export ANTHROPIC_MODEL="glm-5"

# --- OpenRouter (multi-provider gateway) ---
# Sign up at: https://openrouter.ai/
# Supports Anthropic, OpenAI, MiniMax, and many other models
# export OPENROUTER_API_KEY=sk-or-your-key-here

# --- MiniMax (direct API) ---
# Sign up at: https://www.minimax.chat/
# export MINIMAX_API_KEY=your-minimax-key-here

# --- Rate limit retry configuration ---
# RETRIES=1 to disable retries, BACKOFF=0 to skip sleep between retries
export PIPELINE_RATE_LIMIT_RETRIES=3
export PIPELINE_RATE_LIMIT_BACKOFF=65

# --- Stale worker detection ---
# Seconds of inactivity before a worker is considered stale (default: 300)
# export PIPELINE_STALE_WORKER_TIMEOUT=300
# Poll interval for checking staleness (default: 60)
# export PIPELINE_STALE_POLL_INTERVAL=60