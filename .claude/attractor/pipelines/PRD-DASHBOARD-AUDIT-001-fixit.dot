digraph PRD_DASHBOARD_AUDIT_001_fixit {

    node [shape=ellipse, style=filled, fillcolor=lightblue];
    edge [arrowhead=vee, color=gray];

    # =========================================================================
    # Fix-It Pipeline: PRD-DASHBOARD-AUDIT-001 Gap Closure
    # 4 frontend fixes + 1 backend fix + 1 Docker rebuild
    # Topology: codergen -> wait.system3 -> wait.human per cluster
    # =========================================================================

    start [
        label="Start Fix-It"
        handler="start"
        shape=Mdiamond
        fillcolor="lightgreen"
        status="validated"
        style="filled"
    ];

    # =========================================================================
    # Branch 1: Frontend Fixes (4 defects)
    # =========================================================================

    fix_frontend [
        label="Fix 4 Frontend Defects"
        handler="codergen"
        shape=box
        fillcolor="lightyellow"
        status="pending"
        worker_type="frontend-dev-expert"
        sd_path="docs/sds/dashboard-audit-trail/SD-DASHBOARD-AUDIT-FRONTEND-001.md"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        epic_id="FIXIT-FRONTEND"
        bead_id="claude-harness-setup-hjnp"
        target_dir="/Users/theb/Documents/Windsurf/zenagent3/zenagent/agencheck/agencheck-support-frontend"
        project_bank="claude-code-agencheck"
        acceptance="All 4 frontend defects resolved: (1) employer icon added, (2) completed dots filled, (3) statusLabel rendered, (4) polling at 10000ms"
        prompt="You are fixing 4 validation defects in agencheck-support-frontend on branch feat/dashboard-audit-frontend. Make these EXACT changes:\n\n1. components/case-detail/CandidateEmployerCard.tsx: Add a Building icon (from lucide-react) next to the employer name, matching the pattern used for the candidate icon (ShieldUser). Import Building from lucide-react.\n\n2. components/case-detail/TimelineEvent.tsx: Change completed event dots from hollow (bg-white border-slate-300) to filled (bg-teal-500 border-teal-500 text-white). Keep current events as bg-blue-500 animate-pulse. Keep pending events as border-dashed.\n\n3. components/case-detail/CasePageHeader.tsx: The statusLabel prop is accepted but never rendered. Add a Badge component next to the checkType text showing the statusLabel. Import Badge from @/components/ui/badge if not already imported.\n\n4. hooks/useCaseDetail.ts: Change the polling interval from 5000 to 10000 (10 seconds) for active cases. The refetchInterval callback should return 10_000 for non-terminal statuses.\n\nCommit all changes with message: fix(dashboard): resolve 4 validation defects in case detail components"
        style="filled"
    ];

    wait_s3_frontend [
        label="Validate Frontend Fixes"
        handler="wait.system3"
        shape=hexagon
        gate_type="e2e"
        fillcolor="lightyellow"
        status="pending"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        epic_id="FIXIT-FRONTEND"
        style="filled"
    ];

    wait_human_frontend [
        label="Review Frontend Fixes"
        handler="wait.human"
        shape=hexagon
        gate="technical"
        mode="technical"
        fillcolor="lightyellow"
        status="pending"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        epic_id="FIXIT-FRONTEND"
        style="filled"
    ];

    # =========================================================================
    # Branch 2: Backend Fix (StatusLabelMapper)
    # =========================================================================

    fix_backend [
        label="Fix StatusLabelMapper enum mapping"
        handler="codergen"
        shape=box
        fillcolor="lightyellow"
        status="pending"
        worker_type="backend-solutions-engineer"
        sd_path="docs/sds/dashboard-audit-trail/SD-DASHBOARD-AUDIT-001.md"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        epic_id="FIXIT-BACKEND"
        bead_id="claude-harness-setup-nz37"
        target_dir="/Users/theb/Documents/Windsurf/zenagent3/zenagent/agencheck/agencheck-support-agent"
        project_bank="claude-code-agencheck"
        acceptance="StatusLabelMapper._RESULT_STATUS_MAP maps all 14 CallResultStatus enum values explicitly. partial_verification is mapped. No unmapped values rely on fallback."
        prompt="You are fixing a validation defect in agencheck-support-agent on branch feat/dashboard-audit-perstep.\n\nFile: utils/status_labels.py\n\nThe StatusLabelMapper._RESULT_STATUS_MAP is missing the 'partial_verification' value from the CallResultStatus enum. It also contains keys like 'completed_discrepancies' and 'in_progress' that are NOT in the enum.\n\nFix: Ensure _RESULT_STATUS_MAP contains EXACTLY the 14 values from the CallResultStatus enum. Read the enum definition first (likely in a models or types file) to get the exact values, then update the map. Each value must have a human-readable label. The word 'unreachable' must NOT appear in any label.\n\nAlso run the CI export script (scripts/export_status_labels.py) to regenerate the frontend TypeScript constants file.\n\nCommit with message: fix(status-labels): map all 14 CallResultStatus enum values explicitly"
        style="filled"
    ];

    wait_s3_backend [
        label="Validate Backend Fix"
        handler="wait.system3"
        shape=hexagon
        gate_type="e2e"
        fillcolor="lightyellow"
        status="pending"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        epic_id="FIXIT-BACKEND"
        style="filled"
    ];

    wait_human_backend [
        label="Review Backend Fix"
        handler="wait.human"
        shape=hexagon
        gate="technical"
        mode="technical"
        fillcolor="lightyellow"
        status="pending"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        epic_id="FIXIT-BACKEND"
        style="filled"
    ];

    # =========================================================================
    # Branch 3: Docker Rebuild (depends on backend fix)
    # =========================================================================

    rebuild_docker [
        label="Rebuild Docker from feature branch"
        handler="codergen"
        shape=box
        fillcolor="lightyellow"
        status="pending"
        worker_type="backend-solutions-engineer"
        sd_path="docs/sds/dashboard-audit-trail/SD-DASHBOARD-AUDIT-001.md"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        epic_id="FIXIT-DOCKER"
        bead_id="claude-harness-setup-x79p"
        target_dir="/Users/theb/Documents/Windsurf/zenagent3/zenagent/agencheck/agencheck-support-agent"
        project_bank="claude-code-agencheck"
        acceptance="Docker container rebuilt and running. GET /api/v1/cases/1 returns 200 or 404 (not route-missing 404). Container uses feat/dashboard-audit-perstep code."
        prompt="You are rebuilding the Docker container for agencheck-support-agent from the feat/dashboard-audit-perstep branch.\n\nThe current Docker container runs old code that does NOT have the GET /api/v1/cases/{case_id} endpoint.\n\nSteps:\n1. cd to /Users/theb/Documents/Windsurf/zenagent3/zenagent/agencheck/agencheck-support-agent\n2. Make sure you're on branch feat/dashboard-audit-perstep: git checkout feat/dashboard-audit-perstep\n3. Find the docker-compose file (likely docker-compose.yml or similar)\n4. Rebuild the backend service: docker compose build <service-name>\n5. Restart the service: docker compose up -d <service-name>\n6. Wait 10 seconds for startup\n7. Test: curl -s http://localhost:8001/api/v1/cases/1 — should return JSON (200 with data or 404 with proper API error, NOT a route-missing 404)\n8. If successful, report the response\n\nDo NOT modify any code. Just rebuild and restart the Docker container."
        style="filled"
    ];

    wait_s3_docker [
        label="Validate Docker Rebuild"
        handler="wait.system3"
        shape=hexagon
        gate_type="e2e"
        fillcolor="lightyellow"
        status="pending"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        epic_id="FIXIT-DOCKER"
        style="filled"
    ];

    wait_human_docker [
        label="Review Docker Rebuild"
        handler="wait.human"
        shape=hexagon
        gate="technical"
        mode="technical"
        fillcolor="lightyellow"
        status="pending"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        epic_id="FIXIT-DOCKER"
        style="filled"
    ];

    # =========================================================================
    # Exit
    # =========================================================================

    complete [
        label="Fix-It Complete"
        handler="exit"
        shape=Msquare
        fillcolor="lightyellow"
        status="pending"
        style="filled"
    ];

    # =========================================================================
    # Execution flow
    # Frontend and backend fixes run in parallel
    # Docker rebuild waits for backend validation
    # All branches converge at exit
    # =========================================================================

    start -> fix_frontend [label="begin"];
    start -> fix_backend [label="begin"];

    fix_frontend -> wait_s3_frontend [label="impl_complete"];
    wait_s3_frontend -> wait_human_frontend [label="validated"];
    wait_human_frontend -> complete [label="approved"];

    fix_backend -> wait_s3_backend [label="impl_complete"];
    wait_s3_backend -> wait_human_backend [label="validated"];
    wait_human_backend -> rebuild_docker [label="approved"];

    rebuild_docker -> wait_s3_docker [label="impl_complete"];
    wait_s3_docker -> wait_human_docker [label="validated"];
    wait_human_docker -> complete [label="approved"];

    # =========================================================================
    # Metadata
    # =========================================================================
    graph [
        label="PRD-DASHBOARD-AUDIT-001: Fix-It Pipeline (Gap Closure)"
        labelloc=top
        fontname="Helvetica"
        fontsize=12
    ];
}
