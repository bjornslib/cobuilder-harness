// cobuilder-upgrade-e04.dot — Fix 195 pre-existing test failures across 8 categories
digraph "cobuilder-upgrade-e04" {
    graph [
        label="E0.4: Fix Pre-Existing Test Failures"
        labelloc="t"
        fontsize=16
        rankdir="TB"
        prd_ref="PRD-COBUILDER-UPGRADE-001"
        promise_id="promise-ea2e083e"
        target_dir="/Users/theb/Documents/Windsurf/claude-harness-setup"
    ];

    node [fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=9];

    // ===== START =====
    start [
        shape=Mdiamond
        label="START"
        handler="start"
        status="validated"
    ];

    // ===== STREAM 1: Trivial fixes (Cat 1+6+7, ~67 failures) =====
    research_trivial [
        shape=tab
        label="Research: Trivial fixes\n(Cat 1: Node.handler, Cat 6: hook logic, Cat 7: rule count)"
        handler="research"
        worker_type="backend-solutions-engineer"
        status="pending"
        solution_design="docs/specs/cobuilder-upgrade/TS-COBUILDER-UPGRADE-E0.4.md"
        prd_ref="PRD-COBUILDER-UPGRADE-001"
        research_queries="1. How does Node class define handler vs handler_type? 2. What does work_exhaustion_checker return for empty tasks? 3. How many validation rules exist in DEFAULT_RULES?"
        downstream_node="fix_trivial"
    ];

    fix_trivial [
        shape=box
        label="Fix: Trivial test failures\n(67 tests: node.handler, hook logic, rule count)"
        handler="codergen"
        bead_id="claude-harness-setup-6vg9"
        worker_type="backend-solutions-engineer"
        prd_ref="PRD-COBUILDER-UPGRADE-001"
        acceptance="node.handler replaced with handler_type in advanced_rules.py; work_exhaustion_checker tests pass; rule count updated to 20"
        sd_path="docs/specs/cobuilder-upgrade/TS-COBUILDER-UPGRADE-E0.4.md"
        status="pending"
    ];

    validate_trivial [
        shape=hexagon
        label="Validate: Trivial fixes"
        handler="wait.system3"
        gate_type="e2e"
        status="pending"
    ];

    review_trivial [
        shape=hexagon
        label="Review: Trivial fixes"
        handler="wait.human"
        gate="technical"
        mode="technical"
        status="pending"
    ];

    // ===== STREAM 2: Validation & Guardian (Cat 3+4, ~22 failures) =====
    research_validation [
        shape=tab
        label="Research: Validation & guardian\n(Cat 3: guardian prompts, Cat 4: pipeline runner imports)"
        handler="research"
        worker_type="backend-solutions-engineer"
        status="pending"
        solution_design="docs/specs/cobuilder-upgrade/TS-COBUILDER-UPGRADE-E0.4.md"
        prd_ref="PRD-COBUILDER-UPGRADE-001"
        research_queries="1. What signal handler types does guardian prompt builder include? 2. Where do test_e72 tests import pipeline_runner from? 3. What is the canonical module path?"
        downstream_node="fix_validation"
    ];

    fix_validation [
        shape=box
        label="Fix: Validation & guardian tests\n(22 tests: guardian prompts, pipeline runner imports)"
        handler="codergen"
        bead_id="claude-harness-setup-p9oh"
        worker_type="backend-solutions-engineer"
        prd_ref="PRD-COBUILDER-UPGRADE-001"
        acceptance="Guardian prompt includes all signal handler types; pipeline runner tests import from canonical module; 22 tests pass"
        sd_path="docs/specs/cobuilder-upgrade/TS-COBUILDER-UPGRADE-E0.4.md"
        status="pending"
    ];

    validate_validation [
        shape=hexagon
        label="Validate: Validation & guardian fixes"
        handler="wait.system3"
        gate_type="e2e"
        status="pending"
    ];

    review_validation [
        shape=hexagon
        label="Review: Validation & guardian fixes"
        handler="wait.human"
        gate="technical"
        mode="technical"
        status="pending"
    ];

    // ===== STREAM 3: Event bus test isolation (Cat 5, ~49 failures) =====
    research_eventbus [
        shape=tab
        label="Research: Event bus isolation\n(Cat 5: async state pollution, logfire mocking)"
        handler="research"
        worker_type="backend-solutions-engineer"
        status="pending"
        solution_design="docs/specs/cobuilder-upgrade/TS-COBUILDER-UPGRADE-E0.4.md"
        prd_ref="PRD-COBUILDER-UPGRADE-001"
        research_queries="1. Why do event bus tests pass individually but fail in full suite? 2. What async fixtures need cleanup? 3. How is logfire mocked in conftest?"
        downstream_node="fix_eventbus"
    ];

    fix_eventbus [
        shape=box
        label="Fix: Event bus test isolation\n(49 tests: async cleanup, logfire mocking)"
        handler="codergen"
        bead_id="claude-harness-setup-t7j3"
        worker_type="backend-solutions-engineer"
        prd_ref="PRD-COBUILDER-UPGRADE-001"
        acceptance="All 49 event bus tests pass in full suite run (not just isolation); proper async fixture cleanup implemented"
        sd_path="docs/specs/cobuilder-upgrade/TS-COBUILDER-UPGRADE-E0.4.md"
        status="pending"
    ];

    validate_eventbus [
        shape=hexagon
        label="Validate: Event bus fixes"
        handler="wait.system3"
        gate_type="e2e"
        status="pending"
    ];

    review_eventbus [
        shape=hexagon
        label="Review: Event bus fixes"
        handler="wait.human"
        gate="technical"
        mode="technical"
        status="pending"
    ];

    // ===== STREAM 4: E2E & pipeline tests (Cat 2+8, ~29 failures) =====
    research_e2e [
        shape=tab
        label="Research: E2E & pipeline tests\n(Cat 2: completion-state scripts, Cat 8: mixed e2e failures)"
        handler="research"
        worker_type="backend-solutions-engineer"
        status="pending"
        solution_design="docs/specs/cobuilder-upgrade/TS-COBUILDER-UPGRADE-E0.4.md"
        prd_ref="PRD-COBUILDER-UPGRADE-001"
        research_queries="1. What completion-state scripts do tests expect? 2. Where do they exist? 3. What parser/SDK imports are missing in e2e tests?"
        downstream_node="fix_e2e"
    ];

    fix_e2e [
        shape=box
        label="Fix: E2E & pipeline tests\n(29 tests: completion-state, e2e pipeline)"
        handler="codergen"
        bead_id="claude-harness-setup-dpkt"
        worker_type="backend-solutions-engineer"
        prd_ref="PRD-COBUILDER-UPGRADE-001"
        acceptance="Completion-state tests either pass or skip gracefully; E2E pipeline tests pass with correct imports and expectations"
        sd_path="docs/specs/cobuilder-upgrade/TS-COBUILDER-UPGRADE-E0.4.md"
        status="pending"
    ];

    validate_e2e [
        shape=hexagon
        label="Validate: E2E & pipeline fixes"
        handler="wait.system3"
        gate_type="e2e"
        status="pending"
    ];

    review_e2e [
        shape=hexagon
        label="Review: E2E & pipeline fixes"
        handler="wait.human"
        gate="technical"
        mode="technical"
        status="pending"
    ];

    // ===== FINALIZE =====
    finalize [
        shape=Msquare
        label="FINALIZE"
        handler="exit"
        status="pending"
    ];

    // ===== EDGES =====
    // All 4 streams start in parallel from START
    start -> research_trivial [label="begin"];
    start -> research_validation [label="begin"];
    start -> research_eventbus [label="begin"];
    start -> research_e2e [label="begin"];

    // Each stream: research -> fix -> validate -> review
    research_trivial -> fix_trivial [label="research complete"];
    fix_trivial -> validate_trivial [label="impl complete"];
    validate_trivial -> review_trivial [label="system3 validated"];

    research_validation -> fix_validation [label="research complete"];
    fix_validation -> validate_validation [label="impl complete"];
    validate_validation -> review_validation [label="system3 validated"];

    research_eventbus -> fix_eventbus [label="research complete"];
    fix_eventbus -> validate_eventbus [label="impl complete"];
    validate_eventbus -> review_eventbus [label="system3 validated"];

    research_e2e -> fix_e2e [label="research complete"];
    fix_e2e -> validate_e2e [label="impl complete"];
    validate_e2e -> review_e2e [label="system3 validated"];

    // All reviews must pass before finalize
    review_trivial -> finalize [label="approved"];
    review_validation -> finalize [label="approved"];
    review_eventbus -> finalize [label="approved"];
    review_e2e -> finalize [label="approved"];
}
