digraph "PRD-HARNESS-UPGRADE-E4-E6" {
    graph [
        label="PRD-HARNESS-UPGRADE-001: Phase 2 Epics 4-6"
        labelloc="t"
        fontsize=14
        rankdir="TB"
        prd_ref="PRD-HARNESS-UPGRADE-001"
        target_dir="/Users/theb/Documents/Windsurf/claude-harness-setup"
    ];

    node [fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=9];

    start [
        shape=Mdiamond
        label="START"
        handler="start"
        status="validated"
        fillcolor="lightgreen"
        style="filled"
    ];

    impl_e4 [
        shape=box
        label="E4: Sub-Agent Registry + Skill Injection"
        handler="codergen"
        worker_type="backend-solutions-engineer"
        sd_path="docs/sds/harness-upgrade/SD-HARNESS-UPGRADE-001-E4-agent-registry.md"
        acceptance="AC-4.1: All 6 agent types have .claude/agents/*.md with skills_required in frontmatter. AC-4.2: agent-schema.md worker_type enum includes all 6 types. AC-4.3: dispatch_worker.py loads agent definition and injects skill invocations from skills_required. AC-4.4: Missing agent definition is a hard error (not silent fallback)."
        prd_ref="PRD-HARNESS-UPGRADE-001"
        epic_id="E4"
        status="accepted"
    
        fillcolor="palegreen"
    
        style="filled"
    ];

    verify_e4 [
        shape=component
        label="Verify E4: Agent Registry"
        handler="tool"
        command="cd /Users/theb/Documents/Windsurf/claude-harness-setup && python3 -c \"import os, yaml; agents=['frontend-dev-expert','backend-solutions-engineer','tdd-test-engineer','solution-architect','validation-test-agent','ux-designer']; missing=[a for a in agents if not os.path.isfile(f'.claude/agents/{a}.md')]; assert not missing, f'Missing agents: {missing}'; print(f'PASS: All {len(agents)} agent definitions exist'); [print(f'  {a}: skills_required found') for a in agents if 'skills_required' in open(f'.claude/agents/{a}.md').read()]\""
        status="accepted"

        fillcolor="palegreen"

        style="filled"
    ];

    impl_e5 [
        shape=box
        label="E5: Attractor Schema + Validate CLI Extension"
        handler="codergen"
        worker_type="backend-solutions-engineer"
        sd_path="docs/sds/harness-upgrade/SD-HARNESS-UPGRADE-001-E5-schema-validate-cli.md"
        acceptance="AC-5.1: sd_path mandatory on codergen nodes — validate rejects nodes without it. AC-5.2: Full cluster topology check implemented. AC-5.3: worker_type registry check rejects unknown agent types. AC-5.4: wait.human after wait.system3 topology enforced."
        prd_ref="PRD-HARNESS-UPGRADE-001"
        epic_id="E5"
        status="accepted"
    
        fillcolor="palegreen"
    
        style="filled"
    ];

    verify_e5 [
        shape=component
        label="Verify E5: Validation Rules"
        handler="tool"
        command="cd /Users/theb/Documents/Windsurf/claude-harness-setup && python3 -c \"import subprocess, json; r=subprocess.run(['cobuilder','pipeline','validate','.claude/attractor/pipelines/PRD-HARNESS-UPGRADE-E4-E6.dot'],capture_output=True,text=True); print(f'Validate exit code: {r.returncode}'); print(r.stdout[:500] if r.stdout else ''); print(r.stderr[:500] if r.stderr else '')\""
        status="accepted"
    
        fillcolor="palegreen"
    
        style="filled"
    ];

    impl_e6 [
        shape=box
        label="E6: Dispatch Worker Enhancements"
        handler="codergen"
        worker_type="backend-solutions-engineer"
        sd_path="docs/sds/harness-upgrade/SD-HARNESS-UPGRADE-001-E6-dispatch-worker.md"
        acceptance="AC-6.1: Workers run without MCP permission dialogs (bypassPermissions already done). AC-6.2: Workers receive real SD content in initial prompt (already done in E7). AC-6.3: Skill invocations injected into worker initial prompt from skills_required. AC-6.4: ATTRACTOR_SIGNAL_DIR env var set for worker subprocesses. AC-6.5: Signal evidence includes sd_hash field (already done)."
        prd_ref="PRD-HARNESS-UPGRADE-001"
        epic_id="E6"
        status="accepted"
    
        fillcolor="palegreen"
    
        style="filled"
    ];

    verify_e6 [
        shape=component
        label="Verify E6: Dispatch Enhancements"
        handler="tool"
        command="cd /Users/theb/Documents/Windsurf/claude-harness-setup && python3 -c \"content=open('.claude/scripts/attractor/dispatch_worker.py').read(); checks=[('skills_required' in content or 'skill' in content.lower(), 'skill injection logic'), ('ATTRACTOR_SIGNAL_DIR' in content, 'signal dir env var'), ('compute_sd_hash' in content, 'sd_hash function')]; passed=[c[1] for c in checks if c[0]]; failed=[c[1] for c in checks if not c[0]]; print(f'PASS ({len(passed)}/{len(checks)}): {passed}'); [print(f'FAIL: {f}') for f in failed]; assert len(failed)==0, f'Failed checks: {failed}'\""
        status="accepted"
    
        fillcolor="palegreen"
    
        style="filled"
    ];

    finalize [
        shape=Msquare
        label="FINALIZE"
        handler="exit"
        status="accepted"
    
        fillcolor="palegreen"
    
        style="filled"
    ];

    start -> impl_e4 [label="begin"];
    start -> impl_e5 [label="begin"];
    impl_e4 -> verify_e4 [label="impl_complete"];
    impl_e5 -> verify_e5 [label="impl_complete"];
    impl_e4 -> impl_e6 [label="validated"];
    impl_e5 -> impl_e6 [label="validated"];
    impl_e6 -> verify_e6 [label="impl_complete"];
    verify_e4 -> finalize [label="validated"];
    verify_e5 -> finalize [label="validated"];
    verify_e6 -> finalize [label="validated"];
}
