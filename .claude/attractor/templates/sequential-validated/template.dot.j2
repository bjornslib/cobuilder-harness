// Generated from template: sequential-validated v1.0
// PRD: {{ prd_ref }}

digraph "{{ prd_ref }}" {
    graph [
        label="Initiative: {{ prd_ref }}"
        labelloc="t"
        fontsize=16
        rankdir="TB"
        prd_ref="{{ prd_ref }}"
        promise_id="{{ promise_id }}"
        _template="sequential-validated"
        _template_version="1.0"
    ];

    node [fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=9];

    // STAGE 1: PARSE
    start [
        shape=Mdiamond
        label="PARSE\n{{ prd_ref }}"
        handler="start"
        status="pending"
        style=filled
        fillcolor=lightyellow
    ];

    {% if include_research %}
    // RESEARCH
    research [
        shape=tab
        label="Research\n{{ worker.label }}"
        handler="research"
        worker_type="researcher"
        llm="haiku"
        status="pending"
        style=filled
        fillcolor=lightcyan
    ];

    start -> research [label="begin"];
    research -> impl_{{ worker.bead_id | slugify }} [label="findings ready"];
    {% endif %}

    // EXECUTE
    impl_{{ worker.bead_id | slugify }} [
        shape=box
        label="{{ worker.label }}"
        handler="codergen"
        bead_id="{{ worker.bead_id }}"
        worker_type="{{ worker.worker_type }}"
        acceptance="{{ worker.acceptance | truncate(120) }}"
        {% if worker.promise_ac is defined and worker.promise_ac %}promise_ac="{{ worker.promise_ac }}"{% endif %}
        prd_ref="{{ prd_ref }}"
        status="pending"
        style=filled
        fillcolor=lightyellow
    ];

    {% if not include_research %}
    start -> impl_{{ worker.bead_id | slugify }} [label="begin"];
    {% endif %}

    // VALIDATE
    validate_{{ worker.bead_id | slugify }} [
        shape=hexagon
        label="{{ worker.label }}\nValidation"
        handler="wait_human"
        gate="technical"
        mode="technical"
        bead_id="AT-{{ worker.bead_id }}-TECH"
        status="pending"
        style=filled
        fillcolor=lightyellow
    ];

    impl_{{ worker.bead_id | slugify }} -> validate_{{ worker.bead_id | slugify }}
        [label="impl_complete"];

    // DECISION
    decision_{{ worker.bead_id | slugify }} [
        shape=diamond
        label="Result?"
        handler="conditional"
    ];

    validate_{{ worker.bead_id | slugify }} -> decision_{{ worker.bead_id | slugify }};

    decision_{{ worker.bead_id | slugify }} -> finalize [
        label="pass"
        condition="$last_status = 'success'"
        color=green
    ];

    decision_{{ worker.bead_id | slugify }} -> impl_{{ worker.bead_id | slugify }} [
        label="fail\nretry"
        condition="$last_status = 'failure'"
        color=red
        style=dashed
    ];

    // FINALIZE
    finalize [
        shape=Msquare
        label="FINALIZE\n{{ prd_ref }}"
        handler="exit"
        {% if promise_id %}promise_id="{{ promise_id }}"{% endif %}
        status="pending"
        style=filled
        fillcolor=lightyellow
    ];
}
