digraph "PRD-EXAMPLE-FULL-CLUSTER" {
    graph [
        label="Example: Full Codergen Cluster Topology"
        labelloc="t"
        fontsize=16
        rankdir="TB"
        prd_ref="PRD-EXAMPLE-FULL-CLUSTER"
        target_dir="/path/to/impl-repo"
    ];

    node [fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=9];

    start [
        shape=Mdiamond
        label="START"
        handler="start"
        status="validated"
        style="filled"
        fillcolor="lightgreen"
    ];

    // Full codergen cluster following the required topology
    acceptance_test_writer [
        shape=box
        label="Acceptance Test Writer\nGenerate Gherkin tests from PRD"
        handler="acceptance-test-writer"
        sd_path="docs/sds/example/SD-EXAMPLE-001-E1.md"
        acceptance="Generate blind Gherkin acceptance tests from PRD before implementation begins"
        prd_ref="PRD-EXAMPLE-FULL-CLUSTER"
        epic_id="E1"
        bead_id="E1-ATW"
        status="validated"
        style="filled"
        fillcolor="lightgreen"
    ];

    research [
        shape=tab
        label="Research Node\nValidate framework patterns via Context7/Perplexity"
        handler="research"
        sd_path="docs/sds/example/SD-EXAMPLE-001-E1.md"
        acceptance="Validate framework patterns, update Solution Design docs"
        prd_ref="PRD-EXAMPLE-FULL-CLUSTER"
        epic_id="E1"
        bead_id="E1-RESEARCH"
        status="pending"
    ];

    refine [
        shape=note
        label="Refine Node\nRewrite SD with research findings"
        handler="refine"
        sd_path="docs/sds/example/SD-EXAMPLE-001-E1.md"
        acceptance="Rewrite Solution Design with research findings as first-class content"
        prd_ref="PRD-EXAMPLE-FULL-CLUSTER"
        epic_id="E1"
        bead_id="E1-REFINE"
        status="pending"
    ];

    impl_codergen [
        shape=box
        label="Codergen Node\nImplementation Task"
        handler="codergen"
        worker_type="backend-solutions-engineer"
        sd_path="docs/sds/example/SD-EXAMPLE-001-E1.md"
        acceptance="Implement feature per Solution Design with all acceptance criteria met"
        prd_ref="PRD-EXAMPLE-FULL-CLUSTER"
        epic_id="E1"
        bead_id="E1-IMPL"
        status="pending"
    ];

    e2e_gate [
        shape=hexagon
        label="E2E Validation Gate\nAutomated Testing"
        handler="wait.system3"
        gate_type="e2e"
        contract_ref="docs/prds/example/prd-contract.md"
        summary_ref=".claude/summaries/E1-gate-summary.md"
        epic_id="E1"
        bead_id="E1-GATE"
        status="pending"
    ];

    human_review [
        shape=octagon
        label="Human Review Gate\nTechnical/Business Validation"
        handler="wait.human"
        mode="e2e-review"
        summary_ref=".claude/summaries/E1-gate-summary.md"
        epic_id="E1"
        bead_id="E1-REVIEW"
        status="pending"
    ];

    finalize [
        shape=Msquare
        label="FINALIZE"
        handler="exit"
        status="pending"
    ];

    // Connect the full topology
    start -> acceptance_test_writer [label="begin"];
    acceptance_test_writer -> research [label="completed"];
    research -> refine [label="completed"];
    refine -> impl_codergen [label="completed"];
    impl_codergen -> e2e_gate [label="impl_complete"];
    e2e_gate -> human_review [label="validated"];
    human_review -> finalize [label="validated"];

    // Alternative path without research/refine (still valid as research/refine are optional)
    // impl_codergen -> e2e_gate [label="impl_complete"];
}